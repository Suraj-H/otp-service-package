# Copy to `.env` for local runs that use real providers (never commit `.env`).
# Examples in this repo often use in-memory test doubles; these vars matter for production-style wiring.

# HMAC signing secret for OTP hashes (required for real deployments)
OTP_SECRET=

# Twilio SMS (@otp-service/provider-sms-twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Resend email (@otp-service/provider-email-resend) — use the names your app reads from env
RESEND_API_KEY=
RESEND_FROM=

# Optional: real Redis URL if you replace the in-memory client
# REDIS_URL=redis://localhost:6379
